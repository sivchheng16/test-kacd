# ── Public (Vite bakes these into the browser bundle at build time) ──────────
VITE_KID_CLIENT_ID=your_client_id_here
VITE_KID_REDIRECT_URI=https://academy.koompi.org/auth/callback

# ── Secret (server runtime only — read by server.js, never sent to browser) ─
# Pass via docker run -e KID_CLIENT_SECRET=... or docker-compose environment block
# NEVER add VITE_ prefix to these — that would expose them in the JS bundle
KID_CLIENT_ID=your_client_id_here
KID_CLIENT_SECRET=your_client_secret_here

# ── Supabase (server runtime only) ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
# For full server-side access use service role key instead:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ── AI Provider (server-side only — NEVER add VITE_ prefix) ─────────────────
AI_BASE_URL=https://api.moonshot.cn/v1
AI_API_KEY=your_ai_provider_key_here
AI_MODEL=moonshot-v1-32k
